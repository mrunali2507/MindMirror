rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Reflections subcollection — user can only access their own
      match /reflections/{reflectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Drift analysis subcollection — user can only access their own
      match /drift_analysis/{analysisId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Prompts are readable by all authenticated users, writable by none (admin only)
    match /prompts/{promptId} {
      allow read: if request.auth != null;
      allow write: if false; // Only modifiable via Firebase Console or Admin SDK
    }
  }
}
